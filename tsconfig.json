{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ES2022",
        "moduleResolution": "bundler",
        "rootDir": ".",
        "strict": true,
        "strictNullChecks": true,
        "esModuleInterop": true,
        "useDefineForClassFields": true,
        "types": [],
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "noEmit": true
    },
    "include": ["sites/**/*", "src/**/*"],
    "exclude": ["docs/**/*", "node_modules/**/*"]
}
