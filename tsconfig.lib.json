    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "./dist",
        "declaration": true,
        "emitDeclarationOnly": true,
        "noEmit": false
    },
    "include": ["src/**/*"],
    "exclude": ["docs/**/*", "dist/**/*", "node_modules/**/*"]
}
