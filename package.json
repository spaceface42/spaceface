{
    "name": "nextworld",
    "version": "1.3.0",
    "type": "module",
    "devDependencies": {
        "@eslint/js": "^9.39.3",
        "cross-env": "^7.0.3",
        "esbuild": "^0.27.2",
        "eslint": "^9.39.3",
        "typescript": "^5.2.0",
        "typescript-eslint": "^8.56.1"
    },
    "scripts": {
        "build": "npm run build:docs:prod",
        "build:dev": "npm run build:docs",
        "build:prod:pjax": "npm run build:docs:prod",
        "build:prod": "npm run build:docs:prod",
        "build:docs": "esbuild ./src/app/main.ts --bundle --format=esm --target=es2022 --sourcemap --outfile=./docs/dist/main.js",
        "build:docs:prod": "esbuild ./src/app/main.ts --bundle --format=esm --target=es2022 --minify --outfile=./docs/dist/main.js",
        "build:newworlddream": "npm run build:docs",
        "build:newworlddream:prod": "npm run build:docs:prod",
        "build:old:prod:pjax": "cross-env ENTRY=./oldworld/src/app/main.pjax.ts node ./oldworld/bin/build.js && cross-env HTML_IN_DIR=./oldworld/docs.src HTML_OUT_DIR=./oldworld/docs node ./oldworld/bin/build-html.js",
        "build:old:prod": "cross-env ENTRY=./oldworld/src/app/main.prod.ts node ./oldworld/bin/build.js && cross-env HTML_IN_DIR=./oldworld/docs.src HTML_OUT_DIR=./oldworld/docs node ./oldworld/bin/build-html.js",
        "typecheck:docs": "tsc -p ./tsconfig.json --noEmit",
        "typecheck:newworlddream": "npm run typecheck:docs",
        "smoke:docs": "node ./docs/scripts/smoke-check.mjs",
        "smoke:newworlddream": "npm run smoke:docs",
        "verify:docs": "npm run typecheck:docs && npm run build:docs && npm run smoke:docs",
        "verify:newworlddream": "npm run verify:docs",
        "start:docs": "npm run demo:docs",
        "start:newworlddream": "npm run start:docs",
        "serve:docs": "php ./bin/start-newworlddream.php",
        "serve:newworlddream": "npm run serve:docs",
        "demo:docs": "npm run build:docs && npm run serve:docs",
        "demo:newworlddream": "npm run demo:docs",
        "build:html": "cross-env HTML_IN_DIR=./oldworld/docs.src HTML_OUT_DIR=./oldworld/docs node ./oldworld/bin/build-html.js",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src",
        "lint:fix": "eslint src --fix"
    }
}
