{
    "name": "nextworld",
    "version": "1.3.0",
    "type": "module",
    "devDependencies": {
        "@eslint/js": "^9.39.3",
        "cross-env": "^7.0.3",
        "esbuild": "^0.27.2",
        "eslint": "^9.39.3",
        "typescript": "^5.2.0",
        "typescript-eslint": "^8.56.1"
    },
    "scripts": {
        "build": "node ./bin/build.js && node ./bin/build-html.js",
        "build:dev": "tsc -p ./tsconfig.json && cross-env HTML_SWAP_BUNDLE=0 node ./bin/build-html.js",
        "build:prod:pjax": "cross-env ENTRY=./src/app/main.pjax.ts node ./bin/build.js && node ./bin/build-html.js",
        "build:prod": "cross-env ENTRY=./src/app/main.prod.ts node ./bin/build.js && node ./bin/build-html.js",
        "build:newworlddream": "esbuild ./newworlddream/src/app/main.ts --bundle --format=esm --target=es2022 --sourcemap --outfile=./newworlddream/dist/main.js",
        "build:newworlddream:prod": "esbuild ./newworlddream/src/app/main.ts --bundle --format=esm --target=es2022 --minify --outfile=./newworlddream/dist/main.js",
        "start:newworlddream": "npm run demo:newworlddream",
        "serve:newworlddream": "php ./bin/start-newworlddream.php",
        "demo:newworlddream": "npm run build:newworlddream && npm run serve:newworlddream",
        "build:html": "node ./bin/build-html.js",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src",
        "lint:fix": "eslint src --fix"
    }
}
